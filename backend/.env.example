# Comma-separated list of allowed browser origins for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
#
# Custom domains (e.g. www.example.com) must be listed here. Vercel *.vercel.app
# hosts are allowed by default via allow_origin_regex in app code unless you set:
# CORS_DISABLE_VERCEL_REGEX=1
#
# Optional: preload embedding model at startup (needs enough RAM, e.g. Render Starter+)
# AYUR_PRELOAD_MODEL=true
#
# Optional: smaller encode batches on memory-constrained hosts (default 8)
# AYUR_ENCODE_BATCH_SIZE=4
